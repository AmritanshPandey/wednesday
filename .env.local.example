# ── Wednesday environment ─────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values. See SETUP.md for
# exactly where each value comes from. Nothing here is secret on the client
# side except the ones marked SERVER-ONLY (no NEXT_PUBLIC_ prefix).

# ── Firebase Web SDK (client) ─────────────────────────────────────────────
# Firebase console → Project settings → Your apps → SDK setup and configuration.
# These are already filled with the created "wednesday-introductions" project.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBhRmYSst5WFDNCK1b_YgIhO6FNsNiJB4c
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=wednesday-introductions.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=wednesday-introductions
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=wednesday-introductions.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=621975942299
NEXT_PUBLIC_FIREBASE_APP_ID=1:621975942299:web:0d79cc13bc75f21b58823e

# ── Firebase Admin SDK (SERVER-ONLY) ──────────────────────────────────────
# Firebase console → Project settings → Service accounts → Generate new
# private key. Paste the three values from the downloaded JSON. Keep the
# private key's literal \n escapes (do not add real line breaks).
FIREBASE_ADMIN_PROJECT_ID=wednesday-introductions
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Cloudflare R2 (SERVER-ONLY) — profile photo hosting ───────────────────
# Cloudflare dashboard → R2 → Overview (Account ID) and
# Manage R2 API Tokens → Create API token (Access Key ID + Secret).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wednesday-photos
# The bucket's public URL — enable "Public access" (r2.dev) or attach a custom
# domain, e.g. https://pub-xxxx.r2.dev  or  https://photos.yourdomain.com
NEXT_PUBLIC_R2_PUBLIC_URL=

# ── Cron protection (SERVER-ONLY) ─────────────────────────────────────────
# Any long random string. Vercel Cron sends it as a Bearer token so the
# weekly jobs can't be triggered by strangers. Generate: openssl rand -hex 32
CRON_SECRET=

# ── Dev / demo ────────────────────────────────────────────────────────────
# When "true", exposes a dev-only clock override + manual cron triggers so a
# single machine can play a full week without waiting for real Wednesday.
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
